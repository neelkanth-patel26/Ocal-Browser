{
  "name": "ocal",
  "version": "7.7.00",
  "description": "Ocal Browser - Fast, Secure, and Agentic.",
  "main": "main.js",
  "author": "Gaming Network Studio Media Group",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "build-exe": "electron-builder --win portable",
    "build-premium": "electron-builder --win nsis",
    "build-inno": "powershell -ExecutionPolicy Bypass -File build-dist.ps1"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^2.1.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "adm-zip": "^0.6.0",
    "cross-fetch": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1"
  },
  "build": {
    "appId": "com.ocal.browser",
    "productName": "Ocal Browser",
    "copyright": "Copyright © 2026 Gaming Network Studio Media Group",
    "directories": {
      "output": "dist-builder",
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "Portable Document Format",
        "icon": "pdf-icon.ico",
        "role": "Viewer"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "allowElevation": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "runAfterFinish": true,
      "shortcutName": "Ocal"
    }
  }
}
