{
  "name": "ocal",
  "version": "3.0.013-beta",
  "description": "Ocal Browser - Fast, Secure, and Agentic.",
  "main": "main.js",
  "author": "Gaming Network Studio Media Group",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "build-exe": "electron-builder --win portable",
    "build-premium": "electron-builder --win nsis"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "@electron-forge/plugin-fuses": "^7.6.0",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.35.0",
    "adm-zip": "^0.5.16",
    "cross-fetch": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1"
  },
  "build": {
    "appId": "com.ocal.browser",
    "productName": "Ocal Browser",
    "copyright": "Copyright © 2026 Gaming Network Studio Media Group",
    "directories": {
      "output": "dist-builder"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "allowElevation": true,
      "installerIcon": "icon.png",
      "uninstallerIcon": "icon.png",
      "installerHeaderIcon": "icon.png",
      "runAfterFinish": true,
      "shortcutName": "Ocal"
    }
  }
}
